[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/developer_panel.gd" id="1"]

[node name="DeveloperPanel" type="PanelContainer"]
custom_minimum_size = Vector2(520, 540)
visible = false
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="Layout" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Header" type="HBoxContainer" parent="Margin/Layout"]
layout_mode = 2

[node name="Title" type="Label" parent="Margin/Layout/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "开发者工具"
theme_override_font_sizes/font_size = 20

[node name="CloseButton" type="Button" parent="Margin/Layout/Header"]
unique_name_in_owner = true
layout_mode = 2
text = "关闭"

[node name="EnableCheck" type="CheckButton" parent="Margin/Layout"]
unique_name_in_owner = true
layout_mode = 2
text = "开启开发模式（允许修改权威状态）"

[node name="Commands" type="GridContainer" parent="Margin/Layout"]
layout_mode = 2
columns = 3

[node name="SaveButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "手动保存"

[node name="LoadButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "手动加载"

[node name="AutosaveButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "写入自动档"

[node name="HourButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "+1 小时"

[node name="DayButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "+1 天"

[node name="PauseActionButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "暂停行动"

[node name="SuccessActionButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "行动成功"

[node name="FailureActionButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "行动失败"

[node name="CompleteActionButton" type="Button" parent="Margin/Layout/Commands"]
unique_name_in_owner = true
layout_mode = 2
text = "立即完成"

[node name="StatusLabel" type="Label" parent="Margin/Layout"]
unique_name_in_owner = true
layout_mode = 2
text = "就绪"
autowrap_mode = 2

[node name="CommandHelp" type="Label" parent="Margin/Layout"]
layout_mode = 2
text = "命令入口：inspect/seed/take/promote/demote/age/value/tendency/join/leave/position/relationship/action/control/pressure/contested/date/speed/step/pause_settlement"
autowrap_mode = 2

[node name="CommandRow" type="HBoxContainer" parent="Margin/Layout"]
layout_mode = 2

[node name="CommandInput" type="LineEdit" parent="Margin/Layout/CommandRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "例如：age character:00000001 30"

[node name="CommandButton" type="Button" parent="Margin/Layout/CommandRow"]
unique_name_in_owner = true
layout_mode = 2
text = "执行"

[node name="LogView" type="RichTextLabel" parent="Margin/Layout"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
scroll_active = true
